# MongoDB Atlas Connection
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp
DB_NAME=nbfc_loan_system

# JWT Secret (generate a secure random string)
JWT_SECRET=your-super-secret-jwt-key-min-64-chars-long-random-string-here

# Email Configuration (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=your-email@gmail.com

# Mistral AI API Key
MISTRAL_API_KEY=your-mistral-api-key-here

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Admin Credentials
ADMIN_EMAIL=admin@nbfcbank.com
ADMIN_PASSWORD=Admin@123